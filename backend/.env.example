# Copy to backend/.env and fill in values.

AZURE_AUTHORITY=common
AZURE_CLIENT_ID=your-app-client-id

# Fabric auth (pick one):
# 1) default_credential (default) - run: az login --scope https://api.fabric.microsoft.com/.default
# 2) service_principal - set secret + tenant below (best for production multi-user)
# FABRIC_TOKEN_MODE=default_credential
# FABRIC_TOKEN_MODE=service_principal
# FABRIC_TOKEN_MODE=delegated

TENANT_ID=your-tenant-id
AZURE_CLIENT_SECRET=your-client-secret

AUTH_SESSION_DAYS=7
CHAT_HISTORY_RETENTION_DAYS=90
