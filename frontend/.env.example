# Optional: override API URL (no trailing slash)
# Leave unset in dev — mobile uses Vite proxy at /api automatically.
# VITE_API_URL=http://192.168.1.10:8000

# Microsoft sign-in (same tab redirect). Use "common" so any Microsoft work/personal account can sign in.
# VITE_AZURE_AUTHORITY=common
# VITE_AZURE_CLIENT_ID=your-app-client-id
# Backend: AZURE_AUTHORITY=common and AZURE_CLIENT_ID (must match VITE_AZURE_CLIENT_ID).
