# Optional: override API URL (no trailing slash)
# Leave unset in dev — mobile uses Vite proxy at /api automatically.
# VITE_API_URL=http://192.168.1.10:8000

# Microsoft sign-in (same tab redirect). Defaults match backend tenant / Azure CLI public client.
# VITE_AZURE_TENANT_ID=your-tenant-id
# VITE_AZURE_CLIENT_ID=your-app-client-id
# Backend uses AZURE_CLIENT_ID for token exchange (must match VITE_AZURE_CLIENT_ID).
