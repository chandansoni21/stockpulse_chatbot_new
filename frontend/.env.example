# Optional: override API URL (no trailing slash).
# Required in production so chat requests reach the backend directly
# (Vercel proxy times out after ~60s; chat can take several minutes).
# VITE_API_URL=https://your-backend.up.railway.app

# Microsoft sign-in (must match backend AZURE_CLIENT_ID / AZURE_AUTHORITY).
# VITE_AZURE_AUTHORITY=common
# VITE_AZURE_CLIENT_ID=your-app-client-id
